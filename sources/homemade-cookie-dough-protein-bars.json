{
  "name": "Homemade Cookie Dough Protein Bars",
  "description": "No-bake vanilla cookie-dough bars: a butter + oat-flour + protein dough studded with chocolate chips, pressed and topped with a thin melted chocolate shell (chips + coconut oil). Nut-free / gluten-free. The shell is optional — skip it for a lower-fat bar. Maple kept as written (no-bake binder).",
  "tags": [
    "protein",
    "cookie-dough",
    "no-bake",
    "chocolate-shell",
    "bars"
  ],
  "yield": {
    "amount": 5,
    "unit": "bars"
  },
  "content": {
    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "base",
        "instructionText": "Mix the butter, protein, oat flour, maple syrup, salt, vanilla, and chocolate chips with a splash of milk until it comes together. Press evenly into a parchment-lined loaf pan."
      },
      {
        "componentKey": "s1",
        "order": 2,
        "section": "shell",
        "instructionText": "Melt the chocolate chips with the coconut oil and pour over the base, spreading into a thin layer."
      },
      {
        "componentKey": "z1",
        "order": 3,
        "section": "set",
        "instructionText": "Freeze ~10 min to set the shell, then cut into 5 bars."
      }
    ],
