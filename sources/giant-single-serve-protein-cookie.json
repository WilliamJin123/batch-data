{
  "name": "Giant Single-Serve Protein Cookie",
  "description": "Yogurt-based high-protein cookie (no butter/sugar) found on Instagram, untried. Coconut flour subbed to oat flour; sugar-free chips to semi-sweet; 'zero cal sugar' to granulated Splenda. Chocolate chips unspecified in source — assumed 20g.",
  "tags": [
    "cookie",
    "protein",
    "chocolate-chip",
    "yogurt-based",
    "high-protein",
    "to-try"
  ],
  "yield": {
    "amount": 2,
    "unit": "cookies"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Mix all the ingredients together until smooth, folding in the chocolate chips last."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Divide onto parchment paper and press each into a flat round so it bakes evenly."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Bake 7-9 minutes until the edges are set but the center is still soft.",
        "temperature": 350
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Let cool and enjoy."
      }
    ],
