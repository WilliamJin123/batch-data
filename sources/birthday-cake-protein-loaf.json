{
  "name": "Birthday Cake Protein Loaf",
  "description": "An applesauce-based birthday-cake loaf with a Greek-yogurt protein frosting, finished with Fruity Pebbles at serving for crunch. House calibration: the recipe's sugar-substitute is swapped for granulated Splenda, volume-matched to its sweetness (Splenda's small maltodextrin calories are counted); eggs are medium. Birthday-cake-flavored protein is modeled on the vanilla-protein macro.",
  "tags": [
    "cake",
    "birthday-cake",
    "protein",
    "baked",
    "frosted"
  ],
  "yield": {
    "amount": 4,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "cake",
        "instructionText": "Preheat to 350F. Mix the Greek yogurt, applesauce, Splenda, eggs, flour, protein, baking soda, and salt; pour into a 9x5 loaf pan."
      },
      {
        "componentKey": "b2",
        "order": 2,
        "section": "bake",
        "instructionText": "Bake about 50 min until a toothpick comes clean, tenting with foil halfway. Cool.",
        "temperature": 350
      },
      {
        "componentKey": "f1",
        "order": 3,
        "section": "frosting",
        "instructionText": "Whisk the Greek yogurt, protein, cake-batter extract, Splenda, and pudding mix into a thick frosting and spread over the loaf."
      },
      {
        "componentKey": "f2",
        "order": 4,
        "section": "frosting",
        "instructionText": "Top with Fruity Pebbles just before serving to keep them crunchy."
      }
    ],
