{
  "name": "Healthy Protein Blondies",
  "description": "Gluten-free, sugar-free, low-calorie, and high-protein blondies that are a favorite recipe. They are fudgy and delicious. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "bars",
    "blondie",
    "protein"
  ],
  "yield": {
    "amount": 16,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Preheat the oven to 180°C / 360°F."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "In a large bowl, melt the peanut butter in the microwave until just melted."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Add the vanilla, water, sweetener drops, and the yoghurt. Mix well."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Add the baking powder, salt, protein powder, granulated sweetener, and coconut flour."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "Mix until combined."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "Pour the batter into a brownie tin or dish lined with baking paper."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "Bake for 10 minutes. You want them to be just cooked so that they are still fudgey. Do not overcook them."
      },
      {
        "componentKey": "s8",
        "order": 8,
        "instructionText": "As soon as they come out of the oven, transfer them to a baking rack to cool so that they don’t continue cooking in the pan."
      }
    ],
