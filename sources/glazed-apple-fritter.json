{
  "name": "Glazed Apple Fritter",
  "description": "Two single-serve baked apple fritters on an AP-flour/protein base with a thin glaze. House calibration: the recipe's sugar-substitute is swapped for granulated Splenda, volume-matched to its sweetness (Splenda's small maltodextrin calories are counted); eggs are medium. The Swerve brown sugar is replaced with volume-matched Splenda (add a drop of molasses for brown-sugar notes if desired).",
  "tags": [
    "apple-fritter",
    "protein",
    "baked",
    "glazed"
  ],
  "yield": {
    "amount": 2,
    "unit": "fritters"
  },
  "content": {
    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "fritter",
        "instructionText": "Mix the Greek yogurt, melted butter, and Splenda. Stir in the flour, protein, baking powder, cinnamon, and nutmeg, then fold in the diced apple."
      },
      {
        "componentKey": "b2",
        "order": 2,
        "section": "fritter",
        "instructionText": "Preheat to 350F. Shape the batter into 2 fritter rounds on a greased sheet and bake 10-12 min. Cool 10 min.",
        "temperature": 350
      },
      {
        "componentKey": "g1",
        "order": 3,
        "section": "glaze",
        "instructionText": "Stir the Splenda with the water into a glaze and drizzle over the fritters."
      }
    ],
