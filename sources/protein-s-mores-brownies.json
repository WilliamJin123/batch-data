{
  "name": "Protein S'mores Brownies",
  "description": "Need S’more protein? Try these healthy brownies with a s'mores twist. Features a graham cracker base, fudgy brownie layer, and a creamy frosting. Macros per brownie: ~320 calories, 26g protein. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "brownie",
    "smores",
    "protein"
  ],
  "yield": {
    "amount": 4,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Preheat oven to 350°F."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Crush graham crackers and mix with maple syrup. Press this mixture onto the bottom of a 9x5 loaf pan."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Combine all brownie ingredients in a bowl and mix well. Spread this batter evenly over the graham cracker base."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Bake for approximately 45 minutes, or until a toothpick inserted into the center comes out clean. Be careful not to overbake, as this can affect the fudgy texture."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "While the brownies bake, prepare the frosting by mixing all frosting ingredients together until smooth. If using pudding mix, add it to thicken the frosting."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "Once the brownies have cooled slightly, spread the frosting evenly over the top."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "Sprinkle crushed graham crackers over the frosting. If desired, prepare the chocolate drizzle by melting the oil and chocolate together in the microwave in 30-second intervals until smooth, then drizzle over the brownies."
      },
      {
        "componentKey": "s8",
        "order": 8,
        "instructionText": "Cut the brownies into four pieces to create squares. For the best texture and flavor, chill the brownies in the refrigerator before serving."
      }
    ],
