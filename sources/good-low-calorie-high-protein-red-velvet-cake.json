{
  "name": "[Good] Low Calorie High Protein Red Velvet Cake",
  "description": "A delicious and guilt-free red velvet cake that is high in protein and low in calories, perfect for a healthy dessert option. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "cake",
    "red-velvet",
    "protein"
  ],
  "yield": {
    "amount": 12,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Combine all the cake ingredients in a bowl and mix well."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Pour the batter evenly into two round cake molds."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Bake at 350°F for 18 minutes, or until a toothpick inserted into the center comes out clean. Be careful not to overbake."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "While the cake is baking, mix the frosting ingredients together. Once the cake is cooled, decorate it with the frosting."
      }
    ],
