{
  "name": "Sheet Pan Funfetti Snack Cake",
  "description": "A high-protein, low-calorie sheet pan funfetti cake recipe that is easy to make and delicious. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "cake",
    "funfetti",
    "protein"
  ],
  "yield": {
    "amount": 12,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Preheat the oven to 350°F."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Mix all ingredients in a large bowl."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Spray a 9x13 sheet pan with cooking spray and pour the batter in."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Bake for 35 minutes."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "Let cool for 30 minutes."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "Slice into 12 pieces and enjoy."
      }
    ],
