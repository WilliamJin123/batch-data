{
  "name": "Birthday Cake Protein Cookies",
  "description": "Crumbl-style birthday cake protein cookie with protein frosting (inline; sub-recipe candidate). Standalone root - sweetener is maltodextrin-based granulated Splenda. Yield set to 6; flip to 8 via edit/scale for the smaller-cookie macro view.",
  "tags": [
    "crumbl",
    "cookie",
    "protein",
    "birthday-cake"
  ],
  "yield": {
    "amount": 6,
    "unit": "cookies"
  },
  "content": {
    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "Cookie",
        "instructionText": "Mix all cookie ingredients into a dough. If it is dry, add the almond milk 1 tsp at a time until it just comes together."
      },
      {
        "componentKey": "b2",
        "order": 2,
        "section": "Cookie",
        "instructionText": "Chill 20-30 min."
      },
      {
        "componentKey": "b3",
        "order": 3,
        "section": "Cookie",
        "instructionText": "Scoop onto a lined sheet, wet hands, flatten."
      },
      {
        "componentKey": "b4",
        "order": 4,
        "section": "Cookie",
        "temperature": 350,
        "instructionText": "Bake at 350F for 8 min - pull while centers still look soft."
      },
      {
        "componentKey": "b5",
        "order": 5,
        "section": "Frosting",
        "instructionText": "Cool the cookies fully. Beat the frosting ingredients smooth, chill, then frost."
      }
    ],
