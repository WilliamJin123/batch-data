{
  "name": "Birthday Cake Crumbl Cookie",
  "description": "A baked birthday-cake protein cookie: a Greek-yogurt + oat/coconut-flour dough folded with sprinkles, baked soft, then topped with a Greek-yogurt protein frosting set with SF vanilla pudding. A Crumbl-style copycat, but its own yogurt-based formula — distinct from the AP-flour-chassis Birthday Cake Protein Cookies that derive from the Crumbl Base. House note: maple syrup kept as written.",
  "tags": [
    "crumbl",
    "cookie",
    "protein",
    "birthday-cake",
    "frosted"
  ],
  "yield": {
    "amount": 4,
    "unit": "cookies"
  },
  "content": {
    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "cookies",
        "instructionText": "Preheat to 350F and line a baking sheet. Whisk the protein, oat flour, coconut flour, baking powder, and salt. Add the Greek yogurt, maple syrup, egg, and vanilla; mix to a thick cookie dough. Fold in the sprinkles."
      },
      {
        "componentKey": "b2",
        "order": 2,
        "section": "cookies",
        "temperature": 350,
        "timerSeconds": 660,
        "instructionText": "Divide into 4 large cookies and gently flatten the tops. Bake 10-12 min until the edges are set. Cool completely before frosting."
      },
      {
        "componentKey": "f1",
        "order": 3,
        "section": "frosting",
        "instructionText": "Mix the Greek yogurt, protein, pudding mix, and vanilla until smooth and creamy. Frost the cooled cookies and top with extra sprinkles."
      }
    ],
