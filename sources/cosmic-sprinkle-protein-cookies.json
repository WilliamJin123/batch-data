{
  "name": "Cosmic Sprinkle Protein Cookies",
  "description": "Fudgy chocolate protein cookies on a Greek-yogurt/pumpkin base, topped with a cocoa glaze and rainbow sprinkles. House calibration: the recipe's sugar-substitute is swapped for granulated Splenda, volume-matched to its sweetness (Splenda's small maltodextrin calories are counted); eggs are medium.",
  "tags": [
    "cookie",
    "chocolate",
    "protein",
    "baked",
    "frosted"
  ],
  "yield": {
    "amount": 4,
    "unit": "cookies"
  },
  "content": {
    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "cookies",
        "instructionText": "Preheat to 350F. Mix the Greek yogurt, pumpkin, Splenda, egg, and vanilla, then stir in the cocoa, coconut flour, and protein. Scoop into balls with an ice-cream scoop."
      },
      {
        "componentKey": "b2",
        "order": 2,
        "section": "cookies",
        "instructionText": "Bake 10-12 min until set. Cool.",
        "temperature": 350
      },
      {
        "componentKey": "t1",
        "order": 3,
        "section": "topping",
        "instructionText": "Stir milk into the cocoa and Splenda to a glaze, top the cookies, and finish with rainbow sprinkles."
      }
    ],
