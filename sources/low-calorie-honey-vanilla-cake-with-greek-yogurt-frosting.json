{
  "name": "Low Calorie Honey Vanilla Cake with Greek Yogurt Frosting",
  "description": "A light and fluffy honey vanilla cake, made healthier with Greek yogurt frosting. This recipe is designed to be lower in calories and higher in protein, perfect for impressing guests or satisfying a sweet craving. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "cake",
    "honey",
    "protein"
  ],
  "yield": {
    "amount": 7,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "In separate bowls, mix the wet ingredients and the dry ingredients."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Combine the wet and dry mixtures together."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Fill a springform pan no more than halfway up. The pan size can be 5, 6, or 7 inches."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Bake at 305°F for 15 minutes. The baking temperature is lower because the oven runs hot. After 15 minutes, cover the cake with aluminum foil and bake for another 8 minutes."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "Remove the cake from the oven and let it cool in the pan for at least 15 minutes without disturbing it."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "While the cake is cooling, prepare the frosting by mixing the frosting ingredients until the mixture is thick."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "Spread the frosting over the cooled cake."
      },
      {
        "componentKey": "s8",
        "order": 8,
        "instructionText": "Enjoy your cake!"
      },
      {
        "componentKey": "s9",
        "order": 9,
        "instructionText": "Chef’s Note: To make removal easier, line your springform pan with cooking spray and parchment paper. Cut parchment paper to fit the bottom, spray the bottom to help it stick, and then spray the sides."
      }
    ],
