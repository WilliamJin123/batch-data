{
  "name": "Lemon Blueberry Protein Coffee Cake",
  "description": "A baked lemon coffee cake with blueberry pockets and a buttery crumb top, protein-boosted, in an 8x8. House calibration: the monkfruit/stevia blend is replaced with granulated Splenda. Bake until the center is just set with moist crumbs; cool fully before cutting into 9 squares.",
  "tags": [
    "cake",
    "coffee-cake",
    "lemon",
    "blueberry",
    "protein",
    "baked"
  ],
  "yield": {
    "amount": 9,
    "unit": "squares"
  },
  "content": {
    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "cake",
        "instructionText": "Preheat to 350F and line an 8x8 pan. Whisk the flour, protein, Splenda, baking powder, baking soda, salt, and lemon zest, then mix in the eggs, milk, melted butter, lemon juice, and vanilla until just combined. Fold in the blueberries and spread into the pan."
      },
      {
        "componentKey": "cr1",
        "order": 2,
        "section": "crumb",
        "instructionText": "Rub the flour, Splenda, melted butter, lemon zest, and salt together until crumbly and scatter evenly over the batter."
      },
      {
        "componentKey": "bk1",
        "order": 3,
        "section": "bake",
        "temperature": 350,
        "instructionText": "Bake 28-34 min until the center is just set and a toothpick comes out with moist crumbs. Cool completely before slicing into 9 squares."
      }
    ],
