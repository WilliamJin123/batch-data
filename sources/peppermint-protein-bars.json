{
  "name": "Peppermint Protein Bars",
  "description": "Frosted no-bake peppermint bars: a chocolate (cacao + almond-butter) protein base pressed in a loaf pan, topped with a light cream-cheese + Cool Whip protein frosting and crushed peppermint candies. Same frosted-bar format as the Cookie Dough and Lemon bars; the Cool-Whip frosting mirrors the Cool-Whip Protein Frosting sub-recipe. Maple kept as written (no-bake binder).",
  "tags": [
    "protein",
    "peppermint",
    "frosted",
    "chocolate",
    "no-bake",
    "bars"
  ],
  "yield": {
    "amount": 7,
    "unit": "bars"
  },
  "content": {
    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "base",
        "instructionText": "Combine the cacao, protein, almond flour, and salt. Add the maple syrup, almond butter, peppermint extract, vanilla, and milk; mix to a thick dough, adding a little more milk if needed. Press firmly into a parchment-lined loaf pan."
      },
      {
        "componentKey": "f1",
        "order": 2,
        "section": "frosting",
        "instructionText": "Mix the cream cheese, protein, and Cool Whip until smooth. Spread evenly over the base."
      },
      {
        "componentKey": "t1",
        "order": 3,
        "section": "topping",
        "instructionText": "Sprinkle with the crushed peppermint candies. Freeze at least 30 min, then slice into 7 bars. Store covered in the fridge or freezer."
      }
    ],
