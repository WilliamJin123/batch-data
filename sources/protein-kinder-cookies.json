{
  "name": "Protein Kinder Cookies",
  "description": "These are described as 'MY BEST COOKIES EVER!!!' and are protein-enhanced cookies with kinder slices. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "cookie",
    "kinder",
    "protein"
  ],
  "yield": {
    "amount": 6,
    "unit": "cookies"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Mix everything together to form the dough."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Bake at 350°F for 7-8 minutes."
      }
    ],
