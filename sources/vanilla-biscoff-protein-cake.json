{
  "name": "Vanilla & Biscoff Protein Cake",
  "description": "A simple protein cake with vanilla and Biscoff frosting — about 47 g protein per cake (4 servings ≈ 12 g protein, 117 cal each). House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "cake",
    "biscoff",
    "protein"
  ],
  "yield": {
    "amount": 4,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Preheat oven to 180°C and grease a mini cake tin (4 inch)."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Sieve all dry ingredients for the cake into a mixing bowl and whisk to combine."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Add wet ingredients for the cake into a separate bowl and mix to combine."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Pour the cake batter into the mini cake tin and bake for 20 minutes, or until cooked through. Remove from oven and let it cool."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "While the cake is cooling, prepare the frosting by adding all frosting ingredients to a bowl and stirring to combine. Chill in the fridge for 10-15 minutes to thicken."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "Once the cake has cooled and the frosting has thickened, cut the cake in half and spread Biscoff frosting between the layers."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "Place the top half of the cake on and coat the entire cake with the remaining frosting."
      },
      {
        "componentKey": "s8",
        "order": 8,
        "instructionText": "Enjoy your creation!"
      }
    ],
