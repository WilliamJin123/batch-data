{
  "name": "High Protein Carrot Cake",
  "description": "A single-serve, high-protein, no-added-sugar, low-carb, high-fiber, and gluten-free carrot cake that uses vegan protein powder instead of traditional flour. Perfect for a healthy and delicious dessert that fuels your goals. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "carrot-cake",
    "cake",
    "protein"
  ],
  "yield": {
    "amount": 1,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "In a bowl, use a hand blender or whisk to mix the cake ingredients until smooth."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Add the baking powder and a splash of water, then gently fold to combine."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Pour the batter into a greased ramekin and bake in a preheated oven at 180°C for about 20 minutes."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Let cool slightly, then top with yoghurt, chopped nuts, cinnamon, and maple syrup."
      }
    ],
