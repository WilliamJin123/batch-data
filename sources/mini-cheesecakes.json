{
  "name": "Mini Cheesecakes",
  "description": "Individual baked protein cheesecakes in cupcake liners: a buttery graham crust par-baked, topped with a Greek-yogurt + light-cream-cheese protein batter set with cornstarch, sprinkled with cinnamon sugar, baked, chilled, and drizzled with a sweetener icing. In the Cheesecake family alongside the full-size Vanilla Protein Cheesecake. House calibration: monk-fruit and Swerve brown sugar replaced with granulated Splenda (the icing Splenda blends smoother if ground fine).",
  "tags": [
    "cheesecake",
    "protein",
    "mini",
    "graham",
    "baked"
  ],
  "yield": {
    "amount": 7,
    "unit": "cheesecakes"
  },
  "content": {
    "steps": [
      {
        "componentKey": "k1",
        "order": 1,
        "section": "crust",
        "temperature": 350,
        "timerSeconds": 420,
        "instructionText": "Preheat to 350F. Crush the graham crackers fine and mix with the melted butter, Splenda, and cinnamon. Press into cupcake liners. Bake 7 min, then cool 5 min."
      },
      {
        "componentKey": "ba1",
        "order": 2,
        "section": "batter",
        "instructionText": "Whisk the Greek yogurt, Splenda, cream cheese, egg, lemon juice, vanilla, cornstarch, and protein smooth. Scoop evenly over the cooled crusts."
      },
      {
        "componentKey": "t1",
        "order": 3,
        "section": "topping",
        "temperature": 350,
        "timerSeconds": 1200,
        "instructionText": "Stir the cinnamon and Splenda into a cinnamon sugar and sprinkle over the batter. Bake ~20 min until set (not watery). Cool 20 min, then chill 30-60 min."
      },
      {
        "componentKey": "i1",
        "order": 4,
        "section": "icing",
        "instructionText": "Mix the Splenda with a splash of water until drizzle consistency and pipe over the chilled cheesecakes."
      }
    ],
