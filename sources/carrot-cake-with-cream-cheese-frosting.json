{
  "name": "Carrot Cake with Cream Cheese Frosting",
  "description": "An oat-flour carrot cake baked in an 8x8 with a cream-cheese protein frosting, cut into 9. House calibration: the recipe's sugar-substitute is swapped for granulated Splenda, volume-matched to its sweetness (Splenda's small maltodextrin calories are counted); eggs are medium.",
  "tags": [
    "carrot-cake",
    "cake",
    "protein",
    "baked",
    "frosted"
  ],
  "yield": {
    "amount": 9,
    "unit": "squares"
  },
  "content": {
    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "cake",
        "instructionText": "Preheat to 350F and grease an 8x8 dish. Mix the Greek yogurt, protein, eggs, applesauce, Splenda, and vanilla until smooth. Stir in the oat flour, cinnamon, baking powder, and baking soda, then fold in the shredded carrot and walnuts. Spread into the dish."
      },
      {
        "componentKey": "b2",
        "order": 2,
        "section": "cake",
        "instructionText": "Bake 25-30 min until a toothpick comes out clean. Cool completely.",
        "temperature": 350
      },
      {
        "componentKey": "f1",
        "order": 3,
        "section": "frosting",
        "instructionText": "Whip the cream cheese, Greek yogurt, protein, Splenda, and vanilla until smooth and spread over the cooled cake. Cut into 9."
      }
    ],
