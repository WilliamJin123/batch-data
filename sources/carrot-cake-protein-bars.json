{
  "name": "Carrot Cake Protein Bars",
  "description": "Blended-cottage-cheese carrot bars in an 8x8 with a Greek-yogurt icing, cut into 9. House calibration: the recipe's sugar-substitute is swapped for granulated Splenda, volume-matched to its sweetness (Splenda's small maltodextrin calories are counted); eggs are medium. Sugar-free maple syrup is kept as the liquid sweetener.",
  "tags": [
    "carrot-cake",
    "bars",
    "protein",
    "baked",
    "frosted",
    "bakeoff:carrot-base"
  ],
  "yield": {
    "amount": 9,
    "unit": "bars"
  },
  "content": {
    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "bars",
        "instructionText": "Preheat to 350F and line an 8x8 dish. Whisk the cottage cheese, eggs, vanilla, and SF maple syrup, then mix in the flour, grated carrot, baking powder, cinnamon, nutmeg, ginger, and salt. Spread into the dish."
      },
      {
        "componentKey": "b2",
        "order": 2,
        "section": "bars",
        "instructionText": "Bake 25-30 min. Cool completely.",
        "temperature": 350
      },
      {
        "componentKey": "i1",
        "order": 3,
        "section": "icing",
        "instructionText": "Stir the Greek yogurt with the Splenda into an icing, spread over the cooled bars, and dust with cinnamon. Cut into 9."
      }
    ],
