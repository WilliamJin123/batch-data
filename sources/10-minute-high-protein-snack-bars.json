{
  "name": "10-Minute High-Protein Snack Bars",
  "description": "A fast no-bake nut-butter bar: almond meal, protein, and sea salt bound with nut butter, maple syrup, and vanilla into a thick dough, dark chocolate chips folded through, pressed and set in the fridge. Almond-forward and fat-dense (the nut butter + almond meal carry it). Maple kept as written (no-bake binder).",
  "tags": [
    "protein",
    "nut-butter",
    "no-bake",
    "bars"
  ],
  "yield": {
    "amount": 8,
    "unit": "bars"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "section": "dough",
        "instructionText": "Stir the almond meal, protein, and sea salt together. Add the nut butter, maple syrup, and vanilla and mix to a thick dough. Fold in the dark chocolate chips."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "section": "set",
        "instructionText": "Press evenly into a parchment-lined loaf tin. Refrigerate at least 4 hr (or overnight) to set, then slice into 8 bars."
      }
    ],
