    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "Cookie",
        "instructionText": "Mix the dry ingredients together — flour, vanilla protein, Splenda, baking powder."
      },
      {
        "componentKey": "b2",
        "order": 2,
        "section": "Cookie",
        "instructionText": "Add the wet ingredients (egg, egg white, melted butter, almond milk, vanilla) to the dry and mix to a dough."
      },
      {
        "componentKey": "b3",
        "order": 3,
        "section": "Cookie",
        "instructionText": "Coat your hands in flour to make the dough easier to shape; divide into 5 cookies on a lined sheet."
      },
      {
        "componentKey": "b4",
        "order": 4,
        "section": "Cookie",
        "temperature": 350,
        "timerSeconds": 600,
        "instructionText": "Bake at 350F for 10 minutes."
      },
      {
        "componentKey": "b5",
        "order": 5,
        "section": "Cookie",
        "timerSeconds": 900,
        "instructionText": "Allow the cookies to cool fully before frosting."
      },
      {
        "componentKey": "b6",
        "order": 6,
        "section": "Frosting",
        "instructionText": "Mix the Greek yogurt, SF vanilla pudding mix, vanilla, and a dash of salt into a frosting; spread on the cooled cookies (add sprinkles to taste)."
      }
