{
  "name": "Flourless Coconut Greek Yogurt Cake",
  "description": "A naturally gluten-free cake that’s soft, moist, and made with just 7 simple ingredients. No flour, no boxed mix — just real food that tastes like comfort in every bite. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "cake",
    "coconut",
    "protein"
  ],
  "yield": {
    "amount": 8,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Preheat oven to 350°F and line or grease an 8-inch cake pan."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Whisk eggs until light and frothy."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Mix in honey, Greek yogurt, and vanilla until smooth."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Fold in coconut, baking powder, and salt."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "Pour batter into pan and smooth the top."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "Bake for 28–35 minutes until golden and set in the center."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "Cool for 10 minutes before slicing."
      }
    ],
