{
  "name": "Crumbl Base Protein Cookie",
  "description": "The shared base cookie for the crumbl protein-cookie family \u2014 the flavor-neutral vanilla chassis every flavor derives from. Built from the tested-excellent set: Birthday Cake + Lemon dough at 1.5 scoops (the tested ceiling, both rated excellent) plus their shared cornstarch soft-crumb trick, with a lean egg white kept in for low-risk structure. The 20g newcomer's heavier protein-load (2.5+ scoops) stays a queued experiment, not baked in. No flavor identity of its own; default inline vanilla yogurt/Cool-Whip frosting, with per-flavor frostings (cream cheese for red velvet, lemon drizzle, etc.) meant to swap in. Sweetener is granulated Splenda (calorically modeled, never monk fruit).",
  "tags": [
    "crumbl",
    "cookie",
    "protein",
    "base"
  ],
  "yield": {
    "amount": 6,
    "unit": "cookies"
  },
  "content": {
    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "Cookie",
        "instructionText": "Mix the dry ingredients into a bowl \u2014 flour, vanilla protein, Splenda, baking powder, salt."
      },
      {
        "componentKey": "b2",
        "order": 2,
        "section": "Cookie",
        "instructionText": "Add the wet ingredients \u2014 egg, melted butter, Greek yogurt, almond milk, vanilla \u2014 and mix to a dough. If dry, add the almond milk 1 tsp at a time until it just comes together."
      },
      {
        "componentKey": "b3",
        "order": 3,
        "section": "Cookie",
        "instructionText": "Chill 20-30 min, then scoop onto a lined sheet, wet hands, and flatten (this dough barely spreads)."
      },
      {
        "componentKey": "b4",
        "order": 4,
        "section": "Cookie",
        "temperature": 350,
        "timerSeconds": 540,
        "instructionText": "Bake at 350F for ~9 minutes \u2014 pull while the centers still look soft; they firm up as they cool."
      },
      {
        "componentKey": "b5",
        "order": 5,
        "section": "Frosting",
        "instructionText": "Cool the cookies fully. Beat the frosting ingredients smooth, chill, then frost."
      }
    ],
