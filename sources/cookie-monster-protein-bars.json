{
  "name": "Cookie Monster Protein Bars",
  "description": "No-bake cookie-monster bars: a spirulina-blue protein cookie dough with chocolate brownie bites rolled and folded through, plus crushed creme sandwich cookies, pressed and chilled. A mix-in style bar (no frosting layer). Maple kept as written (no-bake binder).",
  "tags": [
    "protein",
    "cookie-monster",
    "no-bake",
    "bars"
  ],
  "yield": {
    "amount": 7,
    "unit": "bars"
  },
  "content": {
    "steps": [
      {
        "componentKey": "d1",
        "order": 1,
        "section": "blue dough",
        "instructionText": "Mix the protein, butter, maple syrup, oat flour, milk, and spirulina into a thick blue dough."
      },
      {
        "componentKey": "br1",
        "order": 2,
        "section": "brownie bites",
        "instructionText": "Mix the protein, maple syrup, cocoa, and almond butter until combined, then roll into mini balls."
      },
      {
        "componentKey": "a1",
        "order": 3,
        "section": "assembly",
        "instructionText": "Fold the brownie balls into the blue dough, add the crushed sandwich cookies, and gently mix. Press into a parchment-lined loaf pan and chill ~20 min until firm. Slice into 7 bars."
      }
    ],
