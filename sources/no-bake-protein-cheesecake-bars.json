{
  "name": "No-Bake Protein Cheesecake Bars",
  "description": "No-bake cheesecake bars: a milk-bound graham-protein crust pressed in a loaf pan, frozen, then topped with a blended cottage-cheese + light-cream-cheese filling set with SF vanilla pudding. A no-bake, sliceable cousin of the baked Vanilla Protein Cheesecake. House calibration: the source's Swerve/monk-fruit is replaced with granulated Splenda. Eat from the freezer or slightly softened.",
  "tags": [
    "cheesecake",
    "protein",
    "no-bake",
    "bars",
    "made"
  ],
  "yield": {
    "amount": 12,
    "unit": "bars"
  },
  "content": {
    "steps": [
      {
        "componentKey": "c1",
        "order": 1,
        "section": "crust",
        "instructionText": "Blend the graham crackers to a fine crumb. Stir in the melted butter, protein powder, and salt until evenly combined, then gradually mix in the milk until the crumb just holds together (add more milk if it looks dry — it should press, not crumble)."
      },
      {
        "componentKey": "c2",
        "order": 2,
        "section": "crust",
        "instructionText": "Press firmly into a parchment-lined loaf pan. Freeze while you make the filling."
      },
      {
        "componentKey": "f1",
        "order": 3,
        "section": "filling",
        "instructionText": "Blend the cottage cheese, cream cheese, Splenda, protein, vanilla, lemon juice, salt, and pudding mix until completely smooth and creamy."
      },
      {
        "componentKey": "z1",
        "order": 4,
        "section": "assembly",
        "instructionText": "Spread the filling evenly over the frozen crust. Freeze at least 1.5 hr, or until firm."
      },
      {
        "componentKey": "z2",
        "order": 5,
        "section": "assembly",
        "instructionText": "Lift out by the parchment and slice into 12 bars. Eat straight from the freezer or after softening a few minutes."
      }
    ],
