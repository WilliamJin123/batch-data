{
  "name": "Salted Caramel Cheesecake Brownie Bars",
  "description": "9 x 120 | 13 p House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "brownie",
    "cheesecake",
    "caramel",
    "protein"
  ],
  "yield": {
    "amount": 12,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Preheat oven to 350°F (175°C). Line an 8x8 inch baking pan with parchment paper."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "For the brownie layer: In a large bowl, whisk together pumpkin purée, Greek yogurt, egg, egg whites, almond milk, and vanilla extract."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "In a separate bowl, whisk together chocolate protein powder, cocoa powder, self-rising flour, sweetener, and salt."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Add the dry ingredients to the wet ingredients and mix until just combined. Do not overmix."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "Spread the brownie batter evenly into the prepared baking pan."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "For the cheesecake filling: In a medium bowl, beat together cream cheese, Greek yogurt, protein powder, egg, sweetener, and vanilla extract until smooth."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "Carefully spoon the cheesecake filling over the brownie batter."
      },
      {
        "componentKey": "s8",
        "order": 8,
        "instructionText": "Bake for 25-30 minutes, or until the cheesecake is set. Let cool completely."
      },
      {
        "componentKey": "s9",
        "order": 9,
        "instructionText": "For the stovetop caramel topping: In a small saucepan, combine sugar-free caramel syrup, almond milk, sweetener, cornstarch, and sea salt."
      },
      {
        "componentKey": "s10",
        "order": 10,
        "instructionText": "Whisk constantly over medium heat until the mixture thickens, about 5-7 minutes. Remove from heat."
      },
      {
        "componentKey": "s11",
        "order": 11,
        "instructionText": "Pour the caramel topping over the cooled cheesecake layer and spread evenly."
      },
      {
        "componentKey": "s12",
        "order": 12,
        "instructionText": "Chill for at least 1 hour to set before cutting into bars."
      }
    ],
