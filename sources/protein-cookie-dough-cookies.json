{
  "name": "Protein Cookie Dough Cookies",
  "description": "Delicious and high-protein cookie dough cookies, perfect for a healthier dessert option. House calibration: the cookie-dough dough and crumble topping use REAL brown sugar for the molasses chew that defines cookie dough; the frosting and other sugar-substitutes are granulated Splenda (volume-matched); any light butter is real butter at matched calories. Imported via batch ingest.",
  "tags": [
    "cookie",
    "protein"
  ],
  "yield": {
    "amount": 6,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "In a large bowl, combine the flour, vanilla protein powder, brown sugar, baking powder, and salt. Mix well."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Add the egg, melted light butter, Greek yogurt, vanilla extract, and almond milk to the dry ingredients. Mix until just combined and a dough forms. Be careful not to overmix."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Preheat oven to 350°F (175°C)."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Scoop the dough using an ice cream scooper and place onto a baking sheet lined with parchment paper."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "Bake for 8-10 minutes. Remove from the oven when the tops still look slightly undercooked, as they will continue to set as they cool."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "While the cookies are cooling, prepare the frosting by mixing the Greek yogurt, zero sugar Cool Whip, vanilla protein powder, sugar-free vanilla pudding mix, sweetener, and salt in a bowl until smooth and creamy. Place the frosting in the refrigerator."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "For the cookie dough topping, combine the oat flour, vanilla protein powder, brown sugar, vanilla extract, and salt in a separate bowl."
      },
      {
        "componentKey": "s8",
        "order": 8,
        "instructionText": "Slowly add almond milk, a little at a time, until a cookie dough texture forms. Roll this mixture into 21 tiny balls."
      },
      {
        "componentKey": "s9",
        "order": 9,
        "instructionText": "Frost each cooled cookie with the prepared frosting."
      },
      {
        "componentKey": "s10",
        "order": 10,
        "instructionText": "Top each frosted cookie with the tiny cookie dough balls and chocolate chips. Enjoy!"
      }
    ],
