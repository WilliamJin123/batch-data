{
  "name": "7 Calorie High Protein Rainbow Cookie",
  "description": "A recipe for high-protein, low-calorie cookies, yielding approximately 88 small cookies. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "cookie",
    "rainbow",
    "protein"
  ],
  "yield": {
    "amount": 88,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Preheat oven to 350°F."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "In a mixing bowl, add all wet ingredients and mix until smooth."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "In another bowl, add all dry ingredients and mix."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Combine wet and dry ingredients."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "Mix thoroughly until a thick batter forms, ensuring there are no clumps. Fold in mix-ins."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "Refrigerate for 15 minutes to firm up the batter."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "Prepare a parchment-lined cookie sheet or a baking sheet with cooking spray. Add batter."
      },
      {
        "componentKey": "s8",
        "order": 8,
        "instructionText": "Add toppings (optional)."
      },
      {
        "componentKey": "s9",
        "order": 9,
        "instructionText": "Bake at 350°F for 15 minutes."
      },
      {
        "componentKey": "s10",
        "order": 10,
        "instructionText": "Remove when slightly underdone; they will continue to set as they cool. Cut into 88 blondies. Then enjoy!"
      }
    ],
