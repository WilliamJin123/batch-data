{
  "name": "68 Calorie High Protein Frosted Boston Cream Donuts",
  "description": "A healthier, high-protein take on Dunkin's Frosted Boston Cream donuts, with only 68 calories per donut. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "cake",
    "donut",
    "boston-cream",
    "protein"
  ],
  "yield": {
    "amount": 12,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Preheat oven to 350 degrees Fahrenheit."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "In a mixing bowl, combine the wet ingredients and mix."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "In another mixing bowl, combine the dry ingredients and mix."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Add the dry ingredients to the wet ingredients and mix and whisk thoroughly."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "In a separate mixing bowl, combine the frosting ingredients and mix thoroughly."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "In another separate mixing bowl, combine the filling ingredients and mix well."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "Let the mixed frosting and mixed filling cool in the refrigerator while the donuts are cooking and resting."
      },
      {
        "componentKey": "s8",
        "order": 8,
        "instructionText": "Spray a muffin tray with cooking spray (avocado oil recommended). Add the batter to 12 muffin molds. Bake at 350 degrees Fahrenheit for 14-15 minutes."
      },
      {
        "componentKey": "s9",
        "order": 9,
        "instructionText": "Let the donuts rest for at least 15 minutes. They will continue to cook internally, so slightly underbaking is ideal."
      },
      {
        "componentKey": "s10",
        "order": 10,
        "instructionText": "Add the filling to a piping bag and cut a small hole in the center of each donut. Fill each donut with the prepared filling."
      },
      {
        "componentKey": "s11",
        "order": 11,
        "instructionText": "Add the frosting to the top of all the donuts. Then enjoy!"
      }
    ],
