{
  "name": "84 Calorie High Protein Layered Cosmic Brownie Cake",
  "description": "A high-protein, low-calorie layered cosmic brownie cake, perfect for a healthier dessert option. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "brownie",
    "cosmic",
    "protein"
  ],
  "yield": {
    "amount": 10,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Preheat oven to 350°F."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "In a mixing bowl, combine the dry ingredients."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Add the wet ingredients to the dry ingredients and mix thoroughly. Place the batter in the fridge for 10 minutes to thicken."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Spray or line 2 small/medium circular baking dishes with parchment paper. Divide the batter evenly between the two dishes. Bake for 10-12 minutes, slightly underbaking. Let cool for at least 12 minutes."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "While the cakes are cooling, prepare the filling frosting in another mixing bowl by stirring the ingredients together."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "In a separate mixing bowl, prepare the top layer frosting by stirring the ingredients together."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "Spread the mixed filling frosting onto one of the cooled cakes and place the other cake on top."
      },
      {
        "componentKey": "s8",
        "order": 8,
        "instructionText": "Apply the mixed top layer frosting to the top cake, then sprinkle with the topping ingredients. Chill in the refrigerator for at least 1 hour to allow the frosting to thicken before serving. Enjoy!"
      }
    ],
