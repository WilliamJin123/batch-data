{
  "name": "High Protein Chocolate Fudge Squares",
  "description": "No protein bars? No problem - make these instead! Made with cottage cheese making the texture 10/10! Super chocolatey, melt in the mouth fudge, so good you could easily devour them all. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "bars",
    "fudge",
    "protein"
  ],
  "yield": {
    "amount": 9,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Blend all ingredients except the melted chocolate."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Pour in melted chocolate and blend briefly or fold through until smooth."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Add a splash of milk if needed to loosen slightly (should be thick but spreadable)."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Spread into a lined container and smooth the top."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "Mix the glaze ingredients and pour over the top. Sprinkle with flaky sea salt."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "Chill in the fridge for 1–2 hours until firm."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "Slice into 9 squares."
      }
    ],
