{
  "name": "Tuxedo Chocolate Cake",
  "description": "A layered protein chocolate cake: a pumpkin + applesauce + cocoa + oat batter (no flour or oil), stacked with a vanilla cream-cheese icing and a chocolate cream-cheese icing both built on Laughing Cow light wedges + Greek yogurt + protein. Inspired by a fitfoodieliving cake. House calibration: all sweetener is granulated Splenda. Bake in 2-3 thin layers, cool, ice, and chill before slicing.",
  "tags": [
    "cake",
    "chocolate",
    "tuxedo",
    "protein",
    "baked",
    "frosted"
  ],
  "yield": {
    "amount": 4,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "c1",
        "order": 1,
        "section": "cake",
        "instructionText": "Blend the pumpkin, applesauce, Splenda, egg whites, vanilla, cocoa, oats, protein, and baking soda into a smooth batter. Divide between 2-3 parchment-lined pans."
      },
      {
        "componentKey": "c2",
        "order": 2,
        "section": "cake",
        "temperature": 350,
        "instructionText": "Bake at 350F for 20-40 min (toothpick clean), depending on pan depth. Cool 10 min in the pan, then turn out and cool completely."
      },
      {
        "componentKey": "iv1",
        "order": 3,
        "section": "vanilla icing",
        "instructionText": "Mix the Laughing Cow, Greek yogurt, Splenda, vanilla, and vanilla protein smooth."
      },
      {
        "componentKey": "ic1",
        "order": 4,
        "section": "chocolate icing",
        "instructionText": "Mix the Laughing Cow, Greek yogurt, Splenda, cocoa, and chocolate protein smooth."
      },
      {
        "componentKey": "a1",
        "order": 5,
        "section": "assemble",
        "instructionText": "Coat the first layer with the vanilla icing, stack the second and coat with the chocolate icing, then top with the final layer. Refrigerate ~30 min before cutting into 4."
      }
    ],
