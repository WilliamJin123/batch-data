{
  "name": "Red Velvet Protein Cookies (Crumbl Base)",
  "description": "Red velvet flavor of the Crumbl base - base chassis + cocoa, a little apple cider vinegar for the buttermilk tang, and red gel color; the frosting pin is swapped from the base default (vanilla) to the Protein Cream-Cheese Frosting. The Crumbl-base branch of the red velvet bake-off (sibling is the oat-base version). Leavening left as the base's (baking powder, no soda) so the tested texture is unchanged - the vinegar is for tang, not lift. Cocoa makes the dough drier, so it leans on the base's add-almond-milk-to-loosen step. Derived off Crumbl Base Protein Cookie. Untested at this chassis.",
  "tags": [
    "crumbl",
    "cookie",
    "protein",
    "red-velvet"
  ],
  "yield": {
    "amount": 6,
    "unit": "cookies"
  },
  "deriveFromRecipe": "Crumbl Base Protein Cookie",
  "overrides": [
    {
      "op": "add",
      "kind": "slot",
      "payload": {
        "componentKey": "sl-cocoa",
        "name": "cocoa powder",
        "resolution": {
          "kind": "raw",
          "libraryIngredientId": "ing-cocoa-powder"
        }
      }
    },
    {
      "op": "add",
      "kind": "slot",
      "payload": {
        "componentKey": "sl-coloring",
        "name": "red gel food coloring",
        "resolution": {
          "kind": "raw",
          "libraryIngredientId": "ing-food-coloring-red"
        }
      }
    },
    {
      "op": "add",
      "kind": "slot",
      "payload": {
        "componentKey": "sl-acv",
        "name": "apple cider vinegar",
        "resolution": {
          "kind": "raw",
          "libraryIngredientId": "ing-acv"
        }
      }
    },
    {
      "op": "add",
      "kind": "usage",
      "payload": {
        "componentKey": "u-cocoa",
        "stepKey": "b1",
        "slotKey": "sl-cocoa",
        "quantityValue": 3,
        "quantityUnit": "tbsp"
      }
    },
    {
      "op": "add",
      "kind": "usage",
      "payload": {
        "componentKey": "u-coloring",
        "stepKey": "b2",
        "slotKey": "sl-coloring",
        "quantityValue": 1,
        "quantityUnit": "tsp"
      }
    },
    {
      "op": "add",
      "kind": "usage",
      "payload": {
        "componentKey": "u-acv",
        "stepKey": "b2",
        "slotKey": "sl-acv",
        "quantityValue": 1,
        "quantityUnit": "tsp"
      }
    },
    {
      "op": "replace",
      "kind": "step",
      "target": "b1",
      "payload": {
        "componentKey": "b1",
        "order": 1,
        "section": "Cookie",
        "instructionText": "Mix the dry ingredients into a bowl - flour, cocoa, vanilla protein, Splenda, baking powder, salt."
      }
    },
    {
      "op": "replace",
      "kind": "step",
      "target": "b2",
      "payload": {
        "componentKey": "b2",
        "order": 2,
        "section": "Cookie",
        "instructionText": "Add the wet ingredients - egg, egg white, melted butter, Greek yogurt, almond milk, vanilla, the red gel coloring, and the vinegar - and mix to a dough. Cocoa makes this drier, so add the almond milk 1 tsp at a time until it just comes together."
      }
    },
    {
      "op": "replace",
      "kind": "step",
      "target": "b5",
      "payload": {
        "componentKey": "b5",
        "order": 5,
        "section": "Frosting",
        "instructionText": "Cool the cookies fully, then frost with the protein cream-cheese frosting (sub-recipe)."
      }
    },
    {
      "op": "replace",
      "kind": "slot",
      "target": "sl-frosting",
      "payload": {
        "componentKey": "sl-frosting",
        "name": "protein cream-cheese frosting",
        "resolution": {
          "kind": "sub_recipe",
          "subRecipeRef": "Protein Cream-Cheese Frosting"
        }
      }
    }
  ]
}
