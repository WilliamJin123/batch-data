{
  "name": "No-Bake Brownie Bars",
  "description": "Single-layer no-bake brownie bars: cocoa, protein, oat flour, and a touch of espresso bound with maple syrup, pumpkin, and milk into a fudgy press-in dough, set in the freezer. No bake — distinct from the baked Fudgy Protein Brownies. Maple syrup is kept as written; in a no-bake bar the liquid sweetener is structural (it binds the press), so it isn't swapped for Splenda.",
  "tags": [
    "brownie",
    "protein",
    "no-bake",
    "bars",
    "chocolate",
    "made"
  ],
  "yield": {
    "amount": 8,
    "unit": "bars"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "section": "dough",
        "instructionText": "Stir the cocoa, protein, espresso powder, oat flour, and salt together. Add the maple syrup, pumpkin, vanilla, and most of the milk and mix to a thick fudgy dough — add the rest of the milk a little at a time only if needed (a little goes a long way). Fold in the chocolate chips and melted butter."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "section": "set",
        "instructionText": "Press the dough firmly into a parchment-lined loaf pan. Freeze 10 min (or refrigerate ~1 hr) until set, then slice into 8 bars. Store in the fridge."
      }
    ],
