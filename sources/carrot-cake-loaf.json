{
  "name": "Carrot Cake Loaf",
  "description": "A plain-flour carrot loaf with no frosting, baked in a tin and sliced into 16. House calibration: the recipe's sugar-substitute is swapped for granulated Splenda, volume-matched to its sweetness (Splenda's small maltodextrin calories are counted); eggs are medium. The drizzle of olive oil is swapped for coconut oil.",
  "tags": [
    "carrot-cake",
    "cake",
    "protein",
    "baked"
  ],
  "yield": {
    "amount": 16,
    "unit": "slices"
  },
