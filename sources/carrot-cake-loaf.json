    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "batter",
        "instructionText": "Mix everything except the carrot into a smooth batter, then fold in the grated carrot. Pour into a lined loaf tin."
      },
      {
        "componentKey": "b2",
        "order": 2,
        "section": "bake",
        "instructionText": "Bake at 180C / 350F about 25 min until set. Cool before slicing into 16.",
        "temperature": 180
      }
    ],
