{
  "name": "Protein Tiramisu (Rice-Cake)",
  "description": "A 2-ramekin no-bake tiramisu: a protein-pudding custard layered with coffee-soaked rice cakes and dusted with cocoa. House calibration: the recipe's sugar-substitute is swapped for granulated Splenda, volume-matched to its sweetness (Splenda's small maltodextrin calories are counted); eggs are medium.",
  "tags": [
    "tiramisu",
    "protein",
    "no-bake"
  ],
  "yield": {
    "amount": 2,
    "unit": "ramekins"
  },
  "content": {
    "steps": [
      {
        "componentKey": "a1",
        "order": 1,
        "section": "cream",
        "instructionText": "Whisk the protein, Splenda, and pudding mix with a little cold water until smooth and runny, then fold in the Greek yogurt to a custard."
      },
      {
        "componentKey": "a2",
        "order": 2,
        "section": "assembly",
        "instructionText": "Brew coffee into a shallow bowl. In each 10oz ramekin layer custard, a coffee-soaked rice cake, custard, another soaked rice cake, custard, a final soaked rice cake, and a last custard layer."
      },
      {
        "componentKey": "a3",
        "order": 3,
        "section": "assembly",
        "instructionText": "Dust the tops with cocoa and serve."
      }
    ],
