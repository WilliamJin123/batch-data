{
  "name": "High-Protein Sugar Cookies",
  "description": "Low-flour protein sugar cookie tuned to kill the rubbery 'pancake' texture: a scoop of whey replaces most flour and SF instant pudding binds moisture for a dense bakery chew. Sweetener is granulated Splenda; pudding modeled as the Simply Delish SF vanilla already in the library; butter is regular unsalted, already halved to 7 g. Leavening is baking powder only (no soda / cream of tartar). Final step is a fridge rest. Source: user. Stated batch macros ~428 kcal / 44P / 41C / 11F (107/cookie at 4).",
  "tags": [
    "cookie",
    "protein",
    "sugar-cookie",
    "high-protein"
  ],
  "yield": {
    "amount": 4,
    "unit": "cookies"
  },
  "content": {
    "steps": [
      {
        "componentKey": "d1",
        "order": 1,
        "section": "Dough",
        "instructionText": "Whisk the dry base — AP flour, whey protein, SF pudding mix, Splenda, baking powder, salt — until there are no protein clumps."
      },
      {
        "componentKey": "d2",
        "order": 2,
        "section": "Dough",
        "instructionText": "Add the melted butter, whole egg, Greek yogurt, and vanilla into the dry mix."
      },
      {
        "componentKey": "d3",
        "order": 3,
        "section": "Dough",
        "timerSeconds": 300,
        "instructionText": "Stir to combine, then stop and let the bowl sit untouched 5 minutes so the whey and pudding starches swell into a shapeable dough. If still tacky, chill 5 more minutes."
      },
      {
        "componentKey": "d4",
        "order": 4,
        "section": "Bake",
        "temperature": 325,
        "instructionText": "Preheat oven/air fryer to 325F. Divide into 4 equal balls on parchment and press down firmly with your palm or a glass — this dough sets in the shape you give it, it won't spread."
      },
      {
        "componentKey": "d5",
        "order": 5,
        "section": "Bake",
        "temperature": 325,
        "timerSeconds": 390,
        "instructionText": "Bake at 325F for 6-7 minutes. Pull the moment the edges look dry and set, even if the centers still look slightly soft — whey dries out fast."
      },
      {
        "componentKey": "d6",
        "order": 6,
        "section": "Bake",
        "timerSeconds": 420,
        "instructionText": "Leave the cookies on the hot sheet 5-10 minutes; residual pan heat finishes the centers without making the protein rubbery."
      },
      {
        "componentKey": "d7",
        "order": 7,
        "section": "Bake",
        "timerSeconds": 600,
        "instructionText": "Final step: rest in the fridge ~10 minutes to fully set, then eat."
      }
    ],
