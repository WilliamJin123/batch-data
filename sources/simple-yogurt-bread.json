{
  "name": "Simple Yogurt Bread",
  "description": "A quick and easy mini loaf of bread made with Greek yogurt and self-raising flour, perfect for air frying or oven baking. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "cake",
    "bread",
    "protein"
  ],
  "yield": {
    "amount": 1,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Mix flour, yogurt, and salt in a bowl until it clumps together."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Using floured hands, shape the dough into a boule. It should not be sticky. Add more flour if necessary."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Air fry at 175°C for 15-20 minutes using the air fry mode. Alternatively, oven bake at 175°C for 35 minutes. If the center is not cooked, flip the bread and cook for an additional 5 minutes."
      }
    ],
