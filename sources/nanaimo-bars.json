{
  "name": "High-Protein Nanaimo Bars",
  "description": "A high-protein, lower-calorie take on the classic three-layer Canadian Nanaimo bar: cocoa-coconut base, butterscotch protein filling, baking-chocolate top. Sweetener modeled as granulated Splenda; the 'or 20g oat flour' alt for coconut flour is not taken. Source: instagram. Stated full batch ~1300 kcal / 83C / 118P / 58F (header lists per-bar at 10 bars, but the directions slice 9 — yield set to 9).",
  "tags": [
    "protein",
    "nanaimo",
    "bars",
    "no-bake",
    "dessert"
  ],
  "yield": {
    "amount": 9,
    "unit": "bars"
  },
  "content": {
    "steps": [
      {
        "componentKey": "n1",
        "order": 1,
        "section": "Base",
        "instructionText": "Toast the shredded coconut ~30 seconds in a nonstick pan until golden brown."
      },
      {
        "componentKey": "n2",
        "order": 2,
        "section": "Base",
        "instructionText": "Mix the dry base ingredients (with the toasted coconut), then add the almond milk and egg whites."
      },
      {
        "componentKey": "n3",
        "order": 3,
        "section": "Base",
        "instructionText": "Line a baking dish with parchment and press down the base layer."
      },
      {
        "componentKey": "n4",
        "order": 4,
        "section": "Filling",
        "instructionText": "Mix the filling ingredients to a glossy frosting consistency and spread over the base."
      },
      {
        "componentKey": "n5",
        "order": 5,
        "section": "Filling",
        "instructionText": "Freeze 20 minutes."
      },
      {
        "componentKey": "n6",
        "order": 6,
        "section": "Top",
        "instructionText": "Melt the baking chocolate and coconut oil together in 30-second intervals; sweeten the melt with liquid monk fruit to taste."
      },
      {
        "componentKey": "n7",
        "order": 7,
        "section": "Top",
        "instructionText": "Pour and spread the chocolate over the bars."
      },
      {
        "componentKey": "n8",
        "order": 8,
        "section": "Top",
        "instructionText": "Set in the fridge ~20 min uncovered, then refrigerate overnight covered. Slice into 9 bars."
      }
    ],
