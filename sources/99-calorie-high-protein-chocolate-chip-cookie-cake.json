{
  "name": "99 Calorie High Protein Chocolate Chip Cookie Cake",
  "description": "A perfect cookie cake for your next birthday party, with a high protein and low calorie count. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "cookie",
    "chocolate-chip",
    "protein"
  ],
  "yield": {
    "amount": 8,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Preheat oven to 350 degrees."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "In a mixing bowl, add the wet ingredients and mix."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "In another mixing bowl, add the dry ingredients and mix."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Combine the wet ingredients with the dry ingredients. Mix thoroughly, avoiding clumps. Add the mix-in ingredients and mix again."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "Chill the cookie dough in the fridge for 15 minutes."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "Prepare a small/medium circular baking dish by lining it with parchment paper or spraying it with cooking spray. Add the cooled cookie dough to the baking dish."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "If needed, wet your hands slightly and flatten the dough in the dish."
      },
      {
        "componentKey": "s8",
        "order": 8,
        "instructionText": "Bake at 350 degrees for 12-15 minutes. Remove from oven when slightly underdone, as it will continue to cook."
      },
      {
        "componentKey": "s9",
        "order": 9,
        "instructionText": "Let the cookie cake rest for 15 minutes. Optionally, decorate the sides of the cake with additional mini chocolate chips. Then enjoy!"
      }
    ],
