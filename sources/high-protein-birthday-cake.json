{
  "name": "High Protein Birthday Cake",
  "description": "A high-protein, lower-calorie birthday cake with frosting, perfect for dessert lovers who want to watch their intake. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "cake",
    "birthday-cake",
    "protein"
  ],
  "yield": {
    "amount": 6,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Mix all your cake ingredients together in a bowl and fold in sprinkles if using."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Pour the batter into one small cake pan or two mini pans (e.g., 4-inch)."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Bake at 350°F for about 20 minutes or until the top is lightly golden."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "While the cake bakes, mix all frosting ingredients together in a bowl until a smooth frosting forms."
      }
    ],
