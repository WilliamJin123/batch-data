{
  "name": "High Protein Banana Bread Cake with Cream Cheese Frosting",
  "description": "4 x 350 | 38 c | 40 p | 10 f House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "cake",
    "banana",
    "protein"
  ],
  "yield": {
    "amount": 4,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Preheat oven to 350°F."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Mix bananas, eggs, Greek yogurt, and vanilla extract until smooth."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Add oat flour, almond flour, baking powder, baking soda, cinnamon, and salt. Mix until combined."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Pour the batter into a greased small baking dish."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "Bake for 25–30 minutes, or until set."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "Let the cake cool completely."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "For the frosting: mix softened light cream cheese, nonfat Greek yogurt, vanilla protein powder, maple syrup or honey, and vanilla until smooth and creamy."
      },
      {
        "componentKey": "s8",
        "order": 8,
        "instructionText": "Spread the frosting over the cooled cake."
      },
      {
        "componentKey": "s9",
        "order": 9,
        "instructionText": "Slice the cake into 4 servings."
      }
    ],
