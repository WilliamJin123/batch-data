{
  "name": "Crumbl Base Protein Cookie",
  "description": "The shared base cookie for the crumbl protein-cookie family — the flavor-neutral vanilla chassis every flavor derives from. Built from the tested-excellent set: Birthday Cake + Lemon dough at 1.5 scoops plus their shared cornstarch soft-crumb trick, with a lean egg white for structure. Frosting is a sub_recipe pin (defaults to the Cool-Whip vanilla protein frosting); flavors swap the pin — cream cheese for red velvet, a lemon drizzle for lemon. The 20g newcomer's heavier protein-load stays a queued experiment. Sweetener is granulated Splenda (calorically modeled, never monk fruit).",
  "tags": [
    "crumbl",
    "cookie",
    "protein",
    "base"
  ],
  "yield": {
    "amount": 6,
    "unit": "cookies"
  },
  "content": {
    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "Cookie",
        "instructionText": "Mix the dry ingredients into a bowl — flour, vanilla protein, Splenda, baking powder, salt."
      },
      {
        "componentKey": "b2",
        "order": 2,
        "section": "Cookie",
        "instructionText": "Add the wet ingredients — egg, melted butter, Greek yogurt, almond milk, vanilla — and mix to a dough. If dry, add the almond milk 1 tsp at a time until it just comes together."
      },
      {
        "componentKey": "b3",
        "order": 3,
        "section": "Cookie",
        "instructionText": "Chill 20-30 min, then scoop onto a lined sheet, wet hands, and flatten (this dough barely spreads)."
      },
      {
        "componentKey": "b4",
        "order": 4,
        "section": "Cookie",
        "temperature": 350,
        "timerSeconds": 540,
        "instructionText": "Bake at 350F for ~9 minutes — pull while the centers still look soft; they firm up as they cool."
      },
      {
        "componentKey": "b5",
        "order": 5,
        "section": "Frosting",
        "instructionText": "Cool the cookies fully, then frost with the vanilla protein frosting (sub-recipe)."
      }
    ],
