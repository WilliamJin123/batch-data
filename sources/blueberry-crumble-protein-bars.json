{
  "name": "Blueberry Crumble Protein Bars",
  "description": "A cooked blueberry filling between a protein crumble crust and topping, baked in an 8x8 and chilled before cutting into 9. House calibration: the recipe's sugar-substitute is swapped for granulated Splenda, volume-matched to its sweetness (Splenda's small maltodextrin calories are counted); eggs are medium. The 55 g cold light butter is replaced with 27 g real butter at matched calories; the 10 g honey in the filling is kept (small, structural).",
  "tags": [
    "bars",
    "blueberry",
    "protein",
    "baked"
  ],
  "yield": {
    "amount": 9,
    "unit": "bars"
  },
  "content": {
    "steps": [
      {
        "componentKey": "f1",
        "order": 1,
        "section": "filling",
        "instructionText": "Simmer the blueberries, Splenda, honey, vanilla, and salt; stir in a cornstarch-and-water slurry and cook 4-6 min until thick and glossy. Cool 10-15 min."
      },
      {
        "componentKey": "c1",
        "order": 2,
        "section": "crumble",
        "instructionText": "Whisk the flour, oat flour, protein, oats, graham crumbs, baking powder, and salt. Cut in the cold butter to chunky crumbs, then fold in a mix of Greek yogurt, applesauce, egg, Splenda, and vanilla into a crumbly dough."
      },
      {
        "componentKey": "a1",
        "order": 3,
        "section": "assembly",
        "instructionText": "Press about 65% of the dough into a lined 8x8 pan; spread the filling; top with the remaining dough in clusters. Bake at 350F 34-38 min until golden and bubbling.",
        "temperature": 350
      },
      {
        "componentKey": "a2",
        "order": 4,
        "section": "assembly",
        "instructionText": "Cool fully, then chill 2 h before cutting into 9 bars."
      }
    ],
