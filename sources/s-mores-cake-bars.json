{
  "name": "S'mores Cake Bars",
  "description": "Childhood s'mores flavor recreated in perfect little cake bars, offering nostalgia with a healthier, protein-packed twist. Ideal for a summer treat. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "bars",
    "smores",
    "protein"
  ],
  "yield": {
    "amount": 12,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Preheat oven to 350°F and line an 8x8 pan with parchment paper or spray."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "In a bowl, combine all of your ingredients for the base until well combined."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Spread the batter into your prepared pan."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Bake for 20–24 minutes or until the center is just set."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "Top with mini marshmallows, extra chocolate chunks, and crushed graham crackers."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "Broil for 30–60 seconds VERY carefully until golden and toasted."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "Allow for them to cool and then slice and enjoy!"
      }
    ],
