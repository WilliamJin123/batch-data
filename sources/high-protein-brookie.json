{
  "name": "High Protein Brookie",
  "description": "A baked two-layer protein 'brookie' built on blended cottage cheese (not flour or butter): a cocoa brownie layer under a vanilla cookie layer, both leavened with baking powder, chocolate chips folded into each. Distinct from the flour-based Fudgy Protein Brownies — this is a cottage-cheese protein bake. House calibration: Swerve brown sugar replaced with granulated Splenda (sweetness-matched).",
  "tags": [
    "brownie",
    "cookie",
    "brookie",
    "protein",
    "baked",
    "high-protein"
  ],
  "yield": {
    "amount": 5,
    "unit": "squares"
  },
  "content": {
    "steps": [
      {
        "componentKey": "br1",
        "order": 1,
        "section": "brownie layer",
        "instructionText": "Combine the chocolate protein, Splenda, blended cottage cheese, cacao, and baking powder. Fold in the chocolate chips and spread into a parchment-lined baking pan."
      },
      {
        "componentKey": "ck1",
        "order": 2,
        "section": "cookie layer",
        "instructionText": "Combine the vanilla protein, Splenda, blended cottage cheese, vanilla, salt, and baking powder. Fold in the chocolate chips and pour over the brownie layer."
      },
      {
        "componentKey": "bk1",
        "order": 3,
        "section": "bake",
        "temperature": 350,
        "timerSeconds": 2700,
        "instructionText": "Bake at 350F for 45 minutes. Cool, then slice into 5 squares."
      }
    ],
