    "notes": [
      {
        "componentKey": "n1",
        "kind": "pitfall",
        "text": "Stir the brownie layer just until combined - overmixing the cottage-cheese base builds structure and you lose the fudgy density.",
        "stepKey": "br1"
      },
      {
        "componentKey": "n2",
        "kind": "technique",
        "text": "The cookie layer is a thick, scoopable dough; if it's too stiff to spread over the brownie, work in milk a teaspoon at a time until it just spreads. Don't thin it all the way to a batter.",
        "stepKey": "ck1"
      },
      {
        "componentKey": "n3",
        "kind": "pitfall",
        "text": "45 min is the ceiling, not the target - protein + cottage cheese dry out fast. Pull when a pick in the cookie layer comes out with a few moist crumbs; the center keeps cooking as it cools.",
        "stepKey": "bk1"
      },
      {
        "componentKey": "n4",
        "kind": "technique",
        "text": "Cool completely in the pan before slicing - warm protein bakes are gummy and tear; they firm into clean squares once fully cool (a fridge chill helps).",
        "stepKey": "bk1"
      }
    ]
  }
