{
  "name": "Peanut Butter Blondie",
  "description": "Peanut butter blondie - a dense, chewy peanut-butter cookie bar. Real peanut butter for richness and fudge plus powdered peanut butter for PB flavor and protein at a fraction of the fat, on the same lean whey + Greek-yogurt backbone as the butterscotch blondie. Brown sugar and a good pinch of salt give the salted-peanut-butter-cookie read. Underbake on purpose.",
  "tags": [
    "bars",
    "blondie",
    "protein",
    "peanut-butter"
  ],
  "yield": {
    "amount": 9,
    "unit": "squares"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Preheat the oven to 350F / 175C. Line an 8x8 pan with parchment, leaving an overhang on two sides."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Melt the peanut butter until loose and pourable (microwave 20-30 sec, stir) and scrape it into a large bowl."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Whisk the brown sugar and Splenda into the warm peanut butter until glossy, then whisk in the whole egg, Greek yogurt, and vanilla until smooth and slightly fluffy."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Add the vanilla whey, powdered peanut butter, AP flour, baking powder, and salt. Fold just until no dry streaks remain. Loosen with the almond milk a splash at a time if it's too stiff to spread."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "Spread level in the pan - thick batter, press it into the corners."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "temperature": 350,
        "instructionText": "Bake at 350F for ~16-20 min; pull when the edges are set and the center still looks slightly underdone with a faint jiggle. UNDERBAKE - peanut butter and whey both dry out fast past done."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "Cool in the pan ~10 min, lift out by the parchment, cool fully, then cut into 9 squares. Chewier the next day."
      }
    ],
