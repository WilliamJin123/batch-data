{
  "name": "Ginormous Chocolate Chip and Chunk Crumbl Cookie",
  "description": "A giant, gooey, chocolate chip and chunk cookie recipe. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "cookie",
    "chocolate-chip",
    "protein"
  ],
  "yield": {
    "amount": 4,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Preheat oven to 350°F."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Whisk wet ingredients until smooth."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Add dry ingredients and mix into a thick, slightly glossy batter."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Fold in chips and chunks."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "Transfer the batter to a greased 5–6 inch springform pan or skillet."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "Top with optional toppings."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "Bake for 15-20 minutes. Pull when the center is slightly underdone for a gooey, oozing center and to prevent it from drying out."
      }
    ],
