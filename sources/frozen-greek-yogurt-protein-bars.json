{
  "name": "Frozen Greek-Yogurt Protein Bars",
  "description": "Frozen yogurt mold bars: nonfat Greek yogurt whipped with chocolate protein and butterscotch SF pudding mix, folded with crushed Ghost cinnamon cereal, set in candy-bar molds, topped with more cereal and a drizzle of zero-sugar chocolate syrup. Freezer-set, crunchy, very lean. Distinct from the cookie-dough/cheesecake bars — a yogurt-base format closer to the Protein Butterscotch Yogurt Pockets.",
  "tags": [
    "protein",
    "frozen",
    "yogurt-based",
    "no-bake",
    "bars"
  ],
  "yield": {
    "amount": 6,
    "unit": "bars"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "section": "mix",
        "instructionText": "Whisk the Greek yogurt, milk, butterscotch pudding mix, and chocolate protein until smooth. Crush about half the cereal and fold it in."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "section": "mold",
        "instructionText": "Pour into candy-bar molds. Sprinkle the remaining cereal on top and drizzle with the zero-sugar chocolate syrup."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "section": "freeze",
        "instructionText": "Freeze 6-12 hr until firm, then unmold. Makes 6 bars."
      }
    ],
