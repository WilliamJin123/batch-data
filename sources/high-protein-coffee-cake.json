{
  "name": "High Protein Coffee Cake",
  "description": "Delicious coffee cake squares with high protein and low calories, perfect for a healthy snack. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "cake",
    "coffee-cake",
    "protein"
  ],
  "yield": {
    "amount": 16,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Preheat oven to 350°F and line an 8x8 inch pan with parchment paper."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "In a large bowl, whisk together the greek yogurt, almond milk, apple sauce, egg, oil, and vanilla."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Add the protein pancake mix and protein powder to the wet ingredients and mix until just combined."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Set the cake batter aside."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "For the streusel, add all streusel ingredients in a bowl and use your hands to combine until you get a sugary crumble."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "Pour half of the cake batter into the prepared pan and layer half of the streusel crumble over the top."
      },
      {
        "componentKey": "s7",
        "order": 7,
        "instructionText": "Pour the remaining batter over the streusel and sprinkle the remaining streusel mix on top."
      },
      {
        "componentKey": "s8",
        "order": 8,
        "instructionText": "Bake for 30-35 minutes, or until a toothpick comes out clean but the cake should still be moist."
      },
      {
        "componentKey": "s9",
        "order": 9,
        "instructionText": "Let the coffee cake cool completely on a baking rack."
      },
      {
        "componentKey": "s10",
        "order": 10,
        "instructionText": "Mix the icing ingredients together and drizzle over the top of the cooled coffee cake."
      },
      {
        "componentKey": "s11",
        "order": 11,
        "instructionText": "Slice and enjoy!"
      }
    ],
