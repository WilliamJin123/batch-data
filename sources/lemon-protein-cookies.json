    "steps": [
      {
        "componentKey": "l1",
        "order": 1,
        "section": "Cookie",
        "instructionText": "Mix all cookie ingredients into a dough. Add almond milk 1 tsp at a time if dry."
      },
      {
        "componentKey": "l2",
        "order": 2,
        "section": "Cookie",
        "instructionText": "Chill 20-30 min."
      },
      {
        "componentKey": "l3",
        "order": 3,
        "section": "Cookie",
        "instructionText": "Scoop onto a lined sheet, wet hands, flatten."
      },
      {
        "componentKey": "l4",
        "order": 4,
        "section": "Cookie",
        "temperature": 350,
        "instructionText": "Bake at 350F for 8 min - pull while centers still look soft."
      },
      {
        "componentKey": "l5",
        "order": 5,
        "section": "Drizzle",
        "instructionText": "Cool fully. Whisk the drizzle smooth and spoon over the cookies."
      }
    ],
