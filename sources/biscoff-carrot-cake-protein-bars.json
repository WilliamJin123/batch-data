{
  "name": "Biscoff Carrot Cake Protein Bars",
  "description": "Soft baked carrot cake bars with Biscoff cookie butter in the batter and a cream-cheese protein frosting, finished with crushed Biscoff. Baked in an 8x8, cut into 12. A baked member of the Protein Bars family. House calibration: the monkfruit/stevia blend (batter and frosting) is replaced with granulated Splenda; the 30 g honey is kept (small, real moisture).",
  "tags": [
    "bars",
    "carrot-cake",
    "biscoff",
    "protein",
    "baked",
    "frosted"
  ],
  "yield": {
    "amount": 12,
    "unit": "bars"
  },
  "content": {
    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "bars",
        "instructionText": "Preheat to 350F and line an 8x8 pan. Mix the carrot, eggs, milk, Biscoff spread, Splenda, honey, vanilla, flour, protein, baking powder, baking soda, cinnamon, nutmeg, and salt until just combined; fold in the crushed Biscoff. Spread into the pan."
      },
      {
        "componentKey": "b2",
        "order": 2,
        "section": "bars",
        "temperature": 350,
        "instructionText": "Bake 22-28 min until set. Let cool completely."
      },
      {
        "componentKey": "f1",
        "order": 3,
        "section": "frosting",
        "instructionText": "Beat the cream cheese smooth, then mix in the protein, milk, Splenda, and vanilla until fluffy and spreadable. Frost the cooled bars and top with crushed Biscoff. Cut into 12."
      }
    ],
