{
  "name": "Low-Calorie, High-Protein Coconut Cake",
  "description": "A delicious and guilt-free low-calorie, high-protein coconut cake, perfect for any occasion, especially Easter. It's so good, you wouldn't even know it's healthy! House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "cake",
    "coconut",
    "protein"
  ],
  "yield": {
    "amount": 6,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Mix all the cake ingredients together."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "Pour the batter evenly into lined 6-inch cake tins."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Bake at 350°F for 20-25 minutes. Do not overbake! Keep an eye on it and use a toothpick to check for doneness."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Allow the cake to cool completely before mixing the frosting and assembling. It is usually best to wait a whole day before decorating and putting it all together."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "Enjoy your delicious low-calorie, high-protein coconut cake!"
      }
    ],
