{
  "name": "Lemon Blueberry Protein Bread",
  "description": "A light protein loaf with blueberry pockets and a set glaze, baked in a loaf tin and cut into 8. House calibration: the recipe's sugar-substitute is swapped for granulated Splenda, volume-matched to its sweetness (Splenda's small maltodextrin calories are counted); eggs are medium. The 18 g light butter is replaced with 9 g real butter at matched calories. Pull it slightly underdone; it keeps cooking as it cools.",
  "tags": [
    "cake",
    "blueberry",
    "lemon",
    "protein",
    "baked",
    "glazed"
  ],
  "yield": {
    "amount": 8,
    "unit": "slices"
  },
  "content": {
    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "batter",
        "instructionText": "Preheat to 350F and line a loaf tin. Whisk the egg, Greek yogurt, almond milk, melted butter, and lemon juice. Combine the flour, protein, Splenda, baking powder, and salt, then fold the dry into the wet. Fold in the blueberries and pour into the tin."
      },
      {
        "componentKey": "b2",
        "order": 2,
        "section": "bake",
        "instructionText": "Bake 30-35 min, pulling it slightly underdone (it keeps cooking). Cool.",
        "temperature": 350
      },
      {
        "componentKey": "g1",
        "order": 3,
        "section": "glaze",
        "instructionText": "Stir the Splenda with the water into a glaze, spread over the cooled loaf, and chill 15 min to set. Slice into 8."
      }
    ],
