{
  "name": "High-Protein Tiramisu (Ladyfinger)",
  "description": "A 9-serving blender tiramisu: a cottage-cheese/Greek-yogurt protein cream layered with coffee-dipped ladyfingers, dusted with cocoa, set overnight. House calibration: the recipe's sugar-substitute is swapped for granulated Splenda, volume-matched to its sweetness (Splenda's small maltodextrin calories are counted); eggs are medium.",
  "tags": [
    "tiramisu",
    "protein",
    "no-bake"
  ],
  "yield": {
    "amount": 9,
    "unit": "servings"
  },
  "content": {
    "steps": [
      {
        "componentKey": "a1",
        "order": 1,
        "section": "cream",
        "instructionText": "Blend the protein, cottage cheese, Greek yogurt, pudding mix, salt, and cinnamon until smooth."
      },
      {
        "componentKey": "a2",
        "order": 2,
        "section": "assembly",
        "instructionText": "Pour coffee into a bowl. Dip half the ladyfingers and line a dish, spread half the cream, and dust with cinnamon. Repeat with the remaining ladyfingers and cream."
      },
      {
        "componentKey": "a3",
        "order": 3,
        "section": "assembly",
        "instructionText": "Dust the top with cocoa and refrigerate overnight."
      }
    ],
