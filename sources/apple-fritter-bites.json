{
  "name": "Apple Fritter Bites",
  "description": "Baked apple-cinnamon protein bites on an oat-flour/whey-isolate base, scooped and glazed. House calibration: the recipe's sugar-substitute is swapped for granulated Splenda, volume-matched to its sweetness (Splenda's small maltodextrin calories are counted); eggs are medium.",
  "tags": [
    "apple-fritter",
    "protein",
    "baked",
    "glazed"
  ],
  "yield": {
    "amount": 12,
    "unit": "bites"
  },
  "content": {
    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "bites",
        "instructionText": "Preheat to 375F and line a sheet. Mix the eggs, applesauce, vanilla, and diced apple, then stir in the whey, oat flour, cinnamon, baking powder, and salt. Scoop into mounds with a cookie scoop."
      },
      {
        "componentKey": "b2",
        "order": 2,
        "section": "bites",
        "instructionText": "Bake 12-15 min until golden. Cool slightly.",
        "temperature": 375
      },
      {
        "componentKey": "g1",
        "order": 3,
        "section": "glaze",
        "instructionText": "Whisk the whey, Splenda, milk, and vanilla into a glaze and drizzle over the warm bites."
      }
    ],
