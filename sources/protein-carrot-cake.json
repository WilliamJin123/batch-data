{
  "name": "Protein Carrot Cake",
  "description": "A protein-packed carrot cake — about 575 cal and 79 g protein for the whole cake (6 slices ≈ 96 cal, 13 g protein, 1 g fat each). Tuned with 1 tsp apple cider vinegar + ½ tsp baking soda for a softer, higher-rising crumb. House calibration: sugar-substitutes → granulated Splenda (volume-matched); any light butter → real butter at matched calories. Imported via `batch ingest`.",
  "tags": [
    "carrot-cake",
    "cake",
    "protein"
  ],
  "yield": {
    "amount": 6,
    "unit": "slices"
  },
  "content": {
    "steps": [
      {
        "componentKey": "s1",
        "order": 1,
        "instructionText": "Prepare the carrots by grating them."
      },
      {
        "componentKey": "s2",
        "order": 2,
        "instructionText": "In a large bowl, combine the grated carrots, nonfat Greek yogurt, egg, protein powder, banana, baking powder, cinnamon, vanilla, and sweetener."
      },
      {
        "componentKey": "s3",
        "order": 3,
        "instructionText": "Mix all ingredients thoroughly until well combined."
      },
      {
        "componentKey": "s4",
        "order": 4,
        "instructionText": "Pour the batter into a prepared baking dish or individual ramekins."
      },
      {
        "componentKey": "s5",
        "order": 5,
        "instructionText": "Bake in a preheated oven at 180°C (350°F) for 30 minutes, or until a toothpick inserted into the center comes out clean."
      },
      {
        "componentKey": "s6",
        "order": 6,
        "instructionText": "Let the cake cool slightly before serving."
      }
    ],
