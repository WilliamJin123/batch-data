{
  "name": "Healthy Lemon Protein Bars",
  "description": "Frosted no-bake lemon bars: an almond-flour + oat-flour protein cookie layer pressed in a loaf pan, topped with a blended cottage-cheese/cream-cheese frosting brightened with lemon and enriched with melted white chocolate. Same frosted-bar format as the Cookie Dough and Peppermint bars. If the frosting is too loose for the brand of cheese used, thicken with extra protein or cream cheese. Maple kept as written (no-bake binder).",
  "tags": [
    "protein",
    "lemon",
    "frosted",
    "no-bake",
    "bars"
  ],
  "yield": {
    "amount": 8,
    "unit": "bars"
  },
  "content": {
    "steps": [
      {
        "componentKey": "b1",
        "order": 1,
        "section": "cookie layer",
        "instructionText": "Mix the protein, almond flour, oat flour, butter, maple syrup, and lemon juice into a dough. Press firmly into a parchment-lined loaf pan; chill while you make the frosting."
      },
      {
        "componentKey": "f1",
        "order": 2,
        "section": "frosting",
        "instructionText": "Blend the cottage cheese, cream cheese, and lemon juice smooth. Melt the white chocolate chips with the coconut oil and stir in, then stir in the protein until thick. Spread over the cookie layer (thicken with more protein or cream cheese if loose)."
      },
      {
        "componentKey": "z1",
        "order": 3,
        "section": "set",
        "instructionText": "Freeze ~20 min until set, then slice into 8 bars."
      }
    ],
